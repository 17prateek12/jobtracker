{
  "manifest_version": 3,
  "name": "Job Tracker",
  "version": "1.0.0",

  "permissions": [
    "activeTab",
    "storage"
  ],

  "host_permissions": [
    "http://localhost:5000/*"
  ],
  

  "action": {
    "default_popup": "popup/popup.html"
  },

  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/selector.js"
      ]
    }
  ]
}